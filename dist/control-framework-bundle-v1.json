    {
      "description": "This control focuses on the high-value Argo CD configuration choices that determine whether drift is corrected or silently allowed to accumulate. It is intended to answer \"what does good look like?\" for Application sync policy, prune behavior, and self-heal posture before teams debug broken syncs in production.\n",
      "detection_modes": [
        "native_rule",
        "derived_comparison"
      ],
      "evidence_expectations": {
        "corroborating_sources": [
          "argocd app get",
          "argocd app diff",
          "kubectl get application -o yaml"
        ],
        "intent_signals": [
          "spec.syncPolicy.automated",
          "spec.syncPolicy.automated.prune",
          "spec.syncPolicy.automated.selfHeal"
        ],
        "live_signals": [
          "status.sync.status",
          "orphaned or undeleted resources after Git removal"
        ]
      },
      "family": "gitops-operators",
      "id": "CTRL-GITOPS-0003",
      "maturity": "seeded",
      "name": "Argo CD sync policy baseline",
      "pattern_refs": [
        {
          "category": "CONFIG",
          "confidence": "medium",
          "id": "CCVE-2025-0128",
          "name": "Argo CD Application with automated sync but no prune",
          "severity": {
            "bucket": "warning",
            "raw": "warning"
          },
          "tags": [],
          "track": "misconfiguration"
        },
        {
          "category": "ORPHAN",
          "confidence": "high",
          "id": "CCVE-2025-2599",
          "name": "ArgoCD 3.x not deleting resources when app removed from Git",
          "severity": {
            "bucket": "critical",
            "raw": "critical"
          },
          "tags": [],
          "track": "misconfiguration"
        },
        {
          "category": "CONFIG",
          "confidence": "high",
          "id": "CCVE-2025-3720",
          "name": "ArgoCD Application has auto-sync and self-heal disabled",
          "severity": {
            "bucket": "warning",
            "raw": "warning"
          },
          "tags": [],
          "track": "misconfiguration"
        }
      ],
      "remediation": {
        "guidance": [
          "Prefer automated sync with explicit prune posture for applications expected to converge continuously.",
          "Enable self-heal deliberately when the platform expects Argo CD to correct manual drift.",
          "Verify prune expectations against live orphan behavior before changing sync policy defaults on shared applications."
        ],
        "safety_class": "review_required",
        "strategy": "config_fix"
      },
      "resource_kinds": [
        "Application"
      ],
      "severity": "high",
      "slug": "argocd-sync-policy-baseline",
