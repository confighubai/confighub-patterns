{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://confighub.ai/schema/framework-definition-v1.schema.json",
  "title": "Framework Definition v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "slug",
    "name",
    "family",
    "summary",
    "description",
    "maturity",
    "control_ids",
    "platforms",
    "tags",
    "outcomes"
  ],
  "properties": {
    "schema_version": {
      "const": "framework-definition-v1"
    },
    "id": {
      "type": "string",
      "pattern": "^FRM-[A-Z0-9-]+$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "enum": [
        "gitops-operators",
        "workload-hardening",
        "rbac-and-identity",
        "network-exposure",
        "secrets-and-credentials",
        "cluster-hardening",
        "platform-best"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "maturity": {
      "type": "string",
      "enum": [
        "seeded",
        "candidate",
        "promoted"
      ]
    },
    "control_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^CTRL-[A-Z0-9-]+$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  }
}
