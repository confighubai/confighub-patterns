{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://confighub.io/schemas/risk-catalog-v1.schema.json",
  "title": "Risk Catalog V1",
  "type": "object",
  "required": [
    "schema_version",
    "content_sha256",
    "total_entries",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "risk-catalog-v1"
    },
    "content_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "total_entries": {
      "type": "integer",
      "minimum": 0
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/riskEntry"
      }
    }
  },
  "$defs": {
    "riskEntry": {
      "type": "object",
      "required": [
        "id",
        "name",
        "category",
        "track",
        "severity",
        "confidence",
        "source_type",
        "tools",
        "detection",
        "remediation",
        "references",
        "tags",
        "remedy",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^CCVE-2025-[0-9]{4}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "track": {
          "type": "string",
          "enum": [
            "misconfiguration",
            "advisory"
          ]
        },
        "severity": {
          "type": "object",
          "required": [
            "raw",
            "bucket"
          ],
          "properties": {
            "raw": {
              "type": "string"
            },
            "bucket": {
              "type": "string",
              "enum": [
                "critical",
                "warning",
                "info"
              ]
            }
          }
        },
        "confidence": {
          "type": "string"
        },
        "source_type": {
          "type": "string"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "detection": {
          "type": "object",
          "required": [
            "kinds",
            "condition",
            "raw"
          ],
          "properties": {
            "kinds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "condition": {
              "type": "string"
            },
            "confidence": {
              "type": [
                "string",
                "null"
              ]
            },
            "raw": {}
          }
        },
        "remediation": {
          "type": "object",
          "required": [
            "steps",
            "commands",
            "raw"
          ],
          "properties": {
            "steps": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "commands": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "raw": {}
          }
        },
        "references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "remedy": {
          "type": "object",
          "required": [
            "type",
            "confidence",
            "auto_classified",
            "safety_class"
          ],
          "properties": {
            "type": {
              "type": [
                "string",
                "null"
              ]
            },
            "confidence": {
              "type": [
                "string",
                "null"
              ]
            },
            "auto_classified": {
              "type": "boolean"
            },
            "safety_class": {
              "type": "string",
              "enum": [
                "manual_only",
                "safe_auto",
                "unsafe_auto"
              ]
            }
          }
        },
        "metadata": {
          "type": "object",
          "required": [
            "file",
            "version_added",
            "deprecated",
            "superseded_by"
          ],
          "properties": {
            "file": {
              "type": "string"
            },
            "version_added": {
              "type": [
                "string",
                "null"
              ]
            },
            "deprecated": {
              "type": "boolean"
            },
            "superseded_by": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    }
  }
}
